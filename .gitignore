# ============================================================
# Disha-Setu — Root .gitignore
# Covers: frontend (React Native/Expo) + backend (Node.js)
# ============================================================

# ── Node / npm ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
.npm/

# ── Environment ────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# ── Expo / React Native ────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
android/
ios/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Build outputs ──────────────────────────────────────────
build/
out/
.next/
.nuxt/
.output/
.cache/
.turbo/

# ── OS files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE / Editor ───────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Logs ───────────────────────────────────────────────────
logs/
*.log

# ── Uploads / Media (local dev only) ──────────────────────
uploads/
tmp/

# ── Test / Coverage ────────────────────────────────────────
coverage/
.nyc_output/
