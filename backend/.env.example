# ============================================================
# DishaSetu Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# NeonDB (Serverless PostgreSQL)
# Get this from your Neon dashboard → Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dishasetu?sslmode=require

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_GUEST_EXPIRES_IN=1d

# Google OAuth (for Google Sign-In verification)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Cloudinary (for photo uploads from feedback reports)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Expo Push Notifications
# No secret needed — Expo handles this via the push token from device

# OTP Settings
OTP_EXPIRY_MINUTES=10
# In development, OTP is returned in the response.
# For production, integrate Twilio or MSG91:
# TWILIO_ACCOUNT_SID=ACxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# CORS — comma-separated list of allowed origins
# For production frontend, add your Web URL here (e.g. from Render/Vercel)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19000,https://dishasetu-frontend.onrender.com

# Geo-fence job interval (minutes)
GEOFENCE_JOB_INTERVAL_MINUTES=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# NewsData.io (optional secondary news source — fallback if Google News RSS is blocked)
# Get a free key at https://newsdata.io — free tier: 200 requests/day
# Leave empty to disable; the service will use structured fallback text instead.
# NEWSDATA_API_KEY=pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
